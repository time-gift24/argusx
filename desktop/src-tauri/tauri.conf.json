{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "argusx-desktop",
  "version": "0.1.0",
  "identifier": "com.argusx.desktop",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "argusx-desktop",
        "width": 1600,
        "height": 1000,
        "minWidth": 1440,
        "minHeight": 900,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
